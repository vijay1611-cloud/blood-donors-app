PORT=4000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/blooddonors?retryWrites=true&w=majority
# Local dev: path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
# Production (Render etc.): paste the full JSON contents on one line; takes precedence over the file path
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Comma-separated list of allowed origins for CORS (e.g. http://localhost:4200)
CORS_ORIGINS=http://localhost:4200
